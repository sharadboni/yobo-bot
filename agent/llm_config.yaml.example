# LLM endpoint configuration
# Each capability has a list of providers tried in order (fallback).
#
# "type" controls the call style:
#   openai     – standard OpenAI SDK calls (default for text/stt/tts)
#   mlx_omni   – mlx-omni-server custom endpoints (vision: POST /v1/vision)
#
# NOTE: mlx-omni-server defaults to port 8765 which conflicts with the
#       WebSocket bridge. Run it on a different port:
#         make run PORT=10240

text:
  - name: local-llm
    base_url: http://YOUR_LAN_IP:52415/v1
    api_key: "no-key"
    model: mlx-community/Qwen3.5-9B-8bit
    max_tokens: 32000
    temperature: 0.5

  - name: openai-fallback
    base_url: https://api.openai.com/v1
    api_key: ${OPENAI_API_KEY}
    model: gpt-4o
    max_tokens: 4096
    temperature: 0.7

vision:
  - name: mlx-omni
    type: mlx_omni
    base_url: http://YOUR_LAN_IP:8765/v1
    api_key: "no-key"
    model: mlx-community/Qwen2.5-VL-3B-Instruct-8bit
    max_tokens: 2048
    temperature: 0.7

stt:
  - name: mlx-omni
    base_url: http://YOUR_LAN_IP:8765/v1
    api_key: "no-key"
    model: mlx-community/Qwen3-ASR-0.6B-8bit

tts:
  - name: mlx-omni
    base_url: http://YOUR_LAN_IP:8765/v1
    api_key: "no-key"
    model: mlx-community/Kokoro-82M-bf16
    voice: af_heart              # Kokoro: af_heart, af_bella, am_adam, bf_alice, etc.
    response_format: opus      # opus | mp3 | aac | flac | wav
    speed: 1.0
