# WebSocket bridge
WS_URL=ws://localhost:8765
WS_PORT=8765

# Logging
LOG_LEVEL=info

# API keys (referenced as ${OPENAI_API_KEY} in llm_config.yaml)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Agent settings
MAX_HISTORY_MESSAGES=50
DATA_DIR=data/users
SEARCH_MAX_RESULTS=5
SERPER_API_KEY=
TAVILY_API_KEY=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://sharadboni.github.io/yobo-bot/

# System prompt
SYSTEM_PROMPT=You are Yobo, a helpful WhatsApp assistant. Be concise and friendly. Respond in the same language the user writes in.
